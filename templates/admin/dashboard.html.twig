{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
    <div class="max-w-7xl mx-auto px-6 py-8">

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold bg-gradient-to-r from-indigo-400 to-purple-500 bg-clip-text text-transparent">
                🚀 PIM Dashboard
            </h1>
            <p class="text-gray-400 mt-2">
                EAV-based product management system (Akeneo-style architecture)
            </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">

            <div class="bg-gray-900 rounded-2xl p-6 shadow-lg border border-gray-800 hover:border-indigo-500 hover:scale-105 transition transform">
                <p class="text-sm text-gray-400">Products</p>
                <p class="text-3xl font-bold mt-2 text-white">{{ productCount }}</p>
            </div>

            <div class="bg-gray-900 rounded-2xl p-6 shadow-lg border border-gray-800 hover:border-indigo-500 hover:scale-105 transition transform">
                <p class="text-sm text-gray-400">Attributes</p>
                <p class="text-3xl font-bold mt-2 text-white">{{ attributeCount }}</p>
            </div>

            <div class="bg-gray-900 rounded-2xl p-6 shadow-lg border border-gray-800 hover:border-indigo-500 hover:scale-105 transition transform">
                <p class="text-sm text-gray-400">Total Values</p>
                <p class="text-3xl font-bold mt-2 text-white">{{ totalValues }}</p>
            </div>

            <div class="bg-gray-900 rounded-2xl p-6 shadow-lg border border-gray-800 hover:border-indigo-500 hover:scale-105 transition transform">
                <p class="text-sm text-gray-400">Avg / Product</p>
                <p class="text-3xl font-bold mt-2 text-white">{{ avgValuesPerProduct }}</p>
            </div>

        </div>

        <!-- Breakdown -->
        <div class="mt-10 bg-gray-900 rounded-2xl p-6 border border-gray-800">
            <h2 class="text-xl font-semibold text-white mb-4">Attribute Value Types</h2>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">

                <div class="bg-gray-800 p-4 rounded-xl text-center hover:scale-105 transition">
                    <p class="text-gray-400 text-sm">Text</p>
                    <p class="text-xl font-bold text-white">{{ textCount }}</p>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl text-center hover:scale-105 transition">
                    <p class="text-gray-400 text-sm">Decimal</p>
                    <p class="text-xl font-bold text-white">{{ decimalCount }}</p>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl text-center hover:scale-105 transition">
                    <p class="text-gray-400 text-sm">Int</p>
                    <p class="text-xl font-bold text-white">{{ intCount }}</p>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl text-center hover:scale-105 transition">
                    <p class="text-gray-400 text-sm">Image</p>
                    <p class="text-xl font-bold text-white">{{ imageCount }}</p>
                </div>

            </div>
        </div>

        <!-- Chart -->
        <div class="mt-10 bg-gray-900 rounded-2xl p-6 border border-gray-800">
            <h2 class="text-xl font-semibold text-white mb-4">Distribution</h2>
            <canvas id="chart"></canvas>
        </div>

    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('chart');

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Text', 'Decimal', 'Int', 'Image'],
                datasets: [{
                    data: [{{ textCount }}, {{ decimalCount }}, {{ intCount }}, {{ imageCount }}],
                }]
            },
            options: {
                plugins: {
                    legend: {
                        labels: {
                            color: '#9CA3AF'
                        }
                    }
                }
            }
        });
    </script>

{% endblock %}
